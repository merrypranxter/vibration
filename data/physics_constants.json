{
  "meta": {"description": "Physics constants and formulas relevant to vibration, acoustics, and wave theory"},
  "constants": {
    "speed_of_sound_air_20C": {"value": 343, "unit": "m/s", "notes": "At 20°C, 1 atm. Approx: v = 331.3 + 0.606·T (T in °C)"},
    "speed_of_sound_water": {"value": 1480, "unit": "m/s", "notes": "Fresh water at 20°C"},
    "speed_of_sound_seawater": {"value": 1520, "unit": "m/s", "notes": "Seawater at 20°C, 35ppt salinity"},
    "speed_of_sound_steel": {"value": 5120, "unit": "m/s", "notes": "Longitudinal waves in steel"},
    "speed_of_sound_aluminum": {"value": 5100, "unit": "m/s", "notes": "Longitudinal waves in aluminum"},
    "speed_of_sound_wood": {"value": 3300, "unit": "m/s", "notes": "Approximate, varies with species and grain direction"},
    "speed_of_light": {"value": 299792458, "unit": "m/s", "symbol": "c"},
    "density_air_20C": {"value": 1.204, "unit": "kg/m³", "notes": "At 20°C, 1 atm"},
    "density_water": {"value": 998, "unit": "kg/m³"},
    "density_steel": {"value": 7800, "unit": "kg/m³"},
    "acoustic_impedance_air": {"value": 413, "unit": "Pa·s/m (rayl)", "formula": "Z = ρ·c", "notes": "Z_air = 1.204 × 343"},
    "acoustic_impedance_water": {"value": 1480000, "unit": "Pa·s/m (rayl)", "notes": "Z_water = 998 × 1480"},
    "reference_sound_pressure": {"value": 0.00002, "unit": "Pa", "notes": "Threshold of hearing at 1 kHz; reference for dB SPL"},
    "reference_sound_intensity": {"value": 1e-12, "unit": "W/m²", "notes": "Reference intensity for dB IL"},
    "planck_constant": {"value": 6.626e-34, "unit": "J·s", "symbol": "h"},
    "boltzmann_constant": {"value": 1.38e-23, "unit": "J/K", "symbol": "k_B"}
  },
  "formulas": {
    "wavelength": {"formula": "λ = v / f", "variables": {"λ": "wavelength (m)", "v": "wave speed (m/s)", "f": "frequency (Hz)"}},
    "period": {"formula": "T = 1 / f", "variables": {"T": "period (s)", "f": "frequency (Hz)"}},
    "angular_frequency": {"formula": "ω = 2πf", "variables": {"ω": "angular frequency (rad/s)", "f": "frequency (Hz)"}},
    "wave_equation": {"formula": "∂²u/∂t² = v² · ∂²u/∂x²", "notes": "1D wave equation; u = displacement, v = wave speed"},
    "wave_general": {"formula": "u(x,t) = A·sin(kx - ωt + φ)", "variables": {"A": "amplitude", "k": "wavenumber = 2π/λ", "ω": "angular frequency", "φ": "phase"}},
    "resonance_string": {"formula": "f_n = n · v / (2L)", "variables": {"n": "mode number (1,2,3,...)", "v": "wave speed in string", "L": "string length"}, "notes": "Fixed-fixed string; v = √(T/μ) where T=tension, μ=linear mass density"},
    "resonance_open_pipe": {"formula": "f_n = n · v / (2L)", "variables": {"n": "mode number", "v": "343 m/s", "L": "pipe length"}, "notes": "Open-open cylindrical pipe; all modes present"},
    "resonance_closed_pipe": {"formula": "f_n = (2n-1) · v / (4L)", "variables": {"n": "mode number (1,2,3,...)"}, "notes": "Closed-open pipe (clarinet); odd modes only"},
    "helmholtz_resonator": {"formula": "f = (c / 2π) · √(A / V·L_eff)", "variables": {"A": "neck cross-sectional area (m²)", "V": "cavity volume (m³)", "L_eff": "effective neck length = L + 0.85·√(A)"}},
    "Q_factor": {"formula": "Q = f_0 / Δf = ω_0 / (2ζω_0) = 1 / (2ζ)", "variables": {"f_0": "resonant frequency", "Δf": "3dB bandwidth", "ζ": "damping ratio"}},
    "damping_ratio": {"formula": "ζ = c / (2·√(k·m))", "variables": {"c": "damping coefficient", "k": "spring constant", "m": "mass"}},
    "beat_frequency": {"formula": "f_beat = |f_1 - f_2|", "notes": "Constructive/destructive interference between two close frequencies"},
    "doppler_effect": {"formula": "f_obs = f_src · (v + v_obs) / (v + v_src)", "notes": "v_obs positive if approaching; v_src positive if receding"},
    "acoustic_impedance": {"formula": "Z = ρ · c", "variables": {"ρ": "medium density (kg/m³)", "c": "sound speed (m/s)"}},
    "reflection_coefficient": {"formula": "R = (Z_2 - Z_1) / (Z_2 + Z_1)", "notes": "Pressure reflection at interface between media 1 and 2"},
    "transmission_coefficient": {"formula": "T = 2·Z_2 / (Z_2 + Z_1)"},
    "sound_intensity": {"formula": "I = p² / (2·Z) = p²_rms / Z", "variables": {"p": "pressure amplitude", "Z": "acoustic impedance"}},
    "decibel_SPL": {"formula": "L_p = 20 · log₁₀(p / p_ref)", "variables": {"p_ref": "2×10⁻⁵ Pa"}, "notes": "dB SPL"},
    "decibel_intensity": {"formula": "L_I = 10 · log₁₀(I / I_ref)", "variables": {"I_ref": "10⁻¹² W/m²"}, "notes": "dB IL"},
    "sabine_reverberation": {"formula": "RT60 = 0.161 · V / A", "variables": {"V": "room volume (m³)", "A": "total absorption (m², sabins)"}, "notes": "Sabine's formula; valid for diffuse fields"},
    "eyring_reverberation": {"formula": "RT60 = -0.161 · V / (S · ln(1-ᾱ))", "variables": {"S": "total surface area", "ᾱ": "mean absorption coefficient"}, "notes": "More accurate than Sabine for high absorption"},
    "power_spectral_density": {"formula": "S_x(f) = lim_{T→∞} (1/T) · |X_T(f)|²", "notes": "Two-sided PSD; one-sided: G_x(f) = 2·S_x(f) for f≥0"},
    "modal_density_3D": {"formula": "n(f) = 4πf²V/c³ + πfS/(2c²) + L/(8c)", "variables": {"V": "volume", "S": "surface area", "L": "total edge length", "c": "sound speed"}}
  }
}
